# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/replycraft

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (SMTP - Zoho)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_SECURE=false

# Account Authentication (Zoho Multi-Identity)
AUTH_EMAIL_USER=auth@replycraft.co.in
AUTH_EMAIL_PASS=your-auth-app-password
AUTH_EMAIL_FROM=ReplyCraft Auth <auth@replycraft.co.in>

SUPPORT_EMAIL_USER=support@replycraft.co.in
SUPPORT_EMAIL_PASS=your-support-app-password
SUPPORT_EMAIL_FROM=ReplyCraft Support <support@replycraft.co.in>

NOREPLY_EMAIL_USER=no-reply@replycraft.co.in
NOREPLY_EMAIL_PASS=your-noreply-app-password
NOREPLY_EMAIL_FROM=ReplyCraft <no-reply@replycraft.co.in>

# Ollama AI Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=mistral
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=60
ALLOWED_MODELS=phi3,mistral,llama3,qwen3.5

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay Payment (India)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google OAuth & Reviews API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
