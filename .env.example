# Server Configuration
PORT=5000
NODE_ENV=development
RUNTIME_ROLE=api

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/replycraft

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Cloudflare Turnstile CAPTCHA
# Create keys in Cloudflare Dashboard -> Turnstile.
# Frontend needs VITE_TURNSTILE_SITE_KEY; backend verifies with this secret.
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Public floating support AI assistant
# Keep the key backend-only. Never expose it in Vercel/frontend env.
SUPPORT_ASSISTANT_AI_ENABLED=false
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_SUPPORT_MODEL=minimaxai/minimax-m2.7
SUPPORT_ASSISTANT_MAX_TOKENS=420

# Email Configuration (SMTP - Zoho)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_SECURE=false

# Account Authentication (Zoho Multi-Identity)
AUTH_EMAIL_USER=auth@replycraft.co.in
AUTH_EMAIL_PASS=your-auth-app-password
AUTH_EMAIL_FROM=ReplyCraft Auth <auth@replycraft.co.in>

SUPPORT_EMAIL_USER=support@replycraft.co.in
SUPPORT_EMAIL_PASS=your-support-app-password
SUPPORT_EMAIL_FROM=ReplyCraft Support <support@replycraft.co.in>

NOREPLY_EMAIL_USER=no-reply@replycraft.co.in
NOREPLY_EMAIL_PASS=your-noreply-app-password
NOREPLY_EMAIL_FROM=ReplyCraft <no-reply@replycraft.co.in>

# Multi-provider AI Configuration
GOOGLE_AI_FLASH_MODEL=gemini-2.5-flash
GOOGLE_AI_PRO_MODEL=gemini-2.5-pro
GOOGLE_AI_MODEL=gemini-2.5-pro
GOOGLE_AI_TEMPERATURE=0.45
GOOGLE_AI_MAX_OUTPUT_TOKENS=220
GOOGLE_AI_TIMEOUT_MS=45000
GOOGLE_AI_KEY_COOLDOWN_MS=900000
GOOGLE_AI_API_KEY_1=your_google_ai_api_key_1
GOOGLE_AI_API_KEY_2=your_google_ai_api_key_2
GOOGLE_AI_API_KEY_3=your_google_ai_api_key_3
GOOGLE_AI_API_KEY_4=your_google_ai_api_key_4
GOOGLE_AI_API_KEY_5=your_google_ai_api_key_5
GOOGLE_AI_API_KEY_6=your_google_ai_api_key_6
GOOGLE_AI_API_KEY_7=your_google_ai_api_key_7
GOOGLE_AI_API_KEY_8=your_google_ai_api_key_8
AWS_ACCESS_KEY_ID=your_bedrock_access_key_id
AWS_SECRET_ACCESS_KEY=your_bedrock_secret_access_key
AWS_SESSION_TOKEN=
AWS_REGION=ap-south-1
BEDROCK_CLAUDE_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
ALLOWED_MODELS=gemini-2.5-flash,gemini-2.5-pro,anthropic.claude-3-sonnet-20240229-v1:0

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay Payment (India)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google OAuth & Reviews API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/dashboard/integrations/google/callback
